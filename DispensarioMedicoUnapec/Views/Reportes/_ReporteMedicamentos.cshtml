@model IEnumerable<DispensarioMedicoUnapec.Models.Medicamento>

<table class="table table-hover align-middle mb-0">
    <thead class="table-light text-secondary small">
        <tr>
            <th class="ps-4 py-3">Nombre</th>
            <th class="py-3">Descripción</th>
            <th class="py-3">Dosis</th>
            <th class="py-3">Tipo de Fármaco</th>
            <th class="py-3">Estado</th>
        </tr>
    </thead>
    <tbody class="border-top-0">
        @foreach (var item in Model)
        {
            <tr>
                <td class="ps-4 fw-semibold text-dark">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px">
                            <i class="bi bi-capsule-pill text-warning small"></i>
                        </div>
                        @item.Nombre
                    </div>
                </td>
                <td class="text-muted" style="max-width:200px;">
                    <span class="d-inline-block text-truncate" style="max-width:180px;" title="@item.Descripcion">@item.Descripcion</span>
                </td>
                <td>
                    <span class="badge bg-light text-dark border rounded-pill px-2">@item.Dosis</span>
                </td>
                <td class="text-secondary">
                    @(item.Tipo_Farmaco != null ? item.Tipo_Farmaco.Nombre : "—")
                </td>
                <td>
                    @if (item.Estado == "Disponible")
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3">
                            <i class="bi bi-check-circle me-1"></i>Disponible
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3">
                            <i class="bi bi-x-circle me-1"></i>@item.Estado
                        </span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>