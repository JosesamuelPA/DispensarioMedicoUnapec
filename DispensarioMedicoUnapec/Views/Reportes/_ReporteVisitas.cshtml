@model IEnumerable<DispensarioMedicoUnapec.Models.Visita>

<table class="table table-hover align-middle mb-0">
    <thead class="table-light text-secondary small">
        <tr>
            <th class="ps-4 py-3">Fecha</th>
            <th class="py-3">Paciente</th>
            <th class="py-3">Médico Tratante</th>
            <th class="py-3">Especialidad</th>
            <th class="py-3">Motivo de Consulta</th>
        </tr>
    </thead>
    <tbody class="border-top-0">
        @foreach (var item in Model)
        {
            <tr>
                <td class="ps-4">
                    <span class="badge bg-light text-dark border rounded-pill px-2">
                        <i class="bi bi-calendar3 me-1 text-info"></i>@item.Fecha.ToString("dd/MM/yyyy")
                    </span>
                    <div><small class="text-muted">@item.Fecha.ToString("HH:mm")</small></div>
                </td>
                <td class="fw-semibold text-dark">
                    @(item.Paciente != null ? item.Paciente.NombreCompleto : "—")
                    @if (item.Paciente != null)
                    {
                        <div><small class="text-muted">@item.Paciente.Cedula</small></div>
                    }
                </td>
                <td>
                    <span class="fw-medium">
                        @(item.Medico != null ? $"Dr. {item.Medico.Nombre} {item.Medico.Apellido}" : "—")
                    </span>
                </td>
                <td>
                    <span class="badge bg-light text-secondary border rounded-pill px-2">
                        @(item.Medico != null ? item.Medico.Especialidad : "—")
                    </span>
                </td>
                <td class="text-muted">@item.Motivo</td>
            </tr>
        }
    </tbody>
</table>