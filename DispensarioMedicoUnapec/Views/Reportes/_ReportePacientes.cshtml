@model IEnumerable<DispensarioMedicoUnapec.Models.Paciente>

<table class="table table-hover align-middle mb-0">
    <thead class="table-light text-secondary small">
        <tr>
            <th class="ps-4 py-3">Nombre Completo</th>
            <th class="py-3">Cédula</th>
            <th class="py-3">Teléfono</th>
            <th class="py-3">No. Carnet</th>
            <th class="py-3">Tipo</th>
            <th class="py-3">Estado</th>
            <th class="py-3 d-print-none text-center">Acciones</th>
        </tr>
    </thead>
    <tbody class="border-top-0">
        @foreach (var item in Model)
        {
            <tr>
                <td class="ps-4 fw-semibold text-dark">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px">
                            <i class="bi bi-person-fill text-primary small"></i>
                        </div>
                        @item.NombreCompleto
                    </div>
                </td>
                <td class="text-muted"><i class="bi bi-person-vcard me-1"></i>@item.Cedula</td>
                <td class="text-muted">@(string.IsNullOrEmpty(item.Telefono) ? "—" : item.Telefono)</td>
                <td class="text-muted">@(string.IsNullOrEmpty(item.Numero_Carnet) ? "—" : item.Numero_Carnet)</td>
                <td>
                    <span class="badge bg-light text-dark border rounded-pill px-2">@item.Tipo_Paciente</span>
                </td>
                <td>
                    @if (item.Estado_Paciente == DispensarioMedicoUnapec.Models.EstadoPaciente.A)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3">
                            <i class="bi bi-check-circle me-1"></i>Activo
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3">
                            <i class="bi bi-x-circle me-1"></i>Inactivo
                        </span>
                    }
                </td>
                <td class="text-center d-print-none">
                    <a asp-controller="Reportes" asp-action="ImprimirExpediente" asp-route-id="@item.Id" target="_blank"
                       class="btn btn-sm btn-outline-primary rounded-pill px-3" title="Imprimir Expediente">
                        <i class="bi bi-printer me-1"></i>Expediente
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>