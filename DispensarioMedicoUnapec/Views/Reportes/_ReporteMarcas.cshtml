@model IEnumerable<DispensarioMedicoUnapec.Models.Marca>

<table class="table table-hover align-middle mb-0">
    <thead class="table-light text-secondary small">
        <tr>
            <th class="ps-4 py-3">Nombre</th>
            <th class="py-3">País de Origen</th>
            <th class="py-3">Descripción</th>
        </tr>
    </thead>
    <tbody class="border-top-0">
        @foreach (var item in Model)
        {
            <tr>
                <td class="ps-4 fw-semibold text-dark">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-secondary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px">
                            <i class="bi bi-patch-check text-secondary small"></i>
                        </div>
                        @item.Nombre
                    </div>
                </td>
                <td>
                    <span class="badge bg-light text-dark border rounded-pill px-2">
                        <i class="bi bi-globe me-1"></i>@item.Pais
                    </span>
                </td>
                <td class="text-muted">@(string.IsNullOrEmpty(item.Descripcion) ? "—" : item.Descripcion)</td>
            </tr>
        }
    </tbody>
</table>