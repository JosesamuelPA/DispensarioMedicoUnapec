@model IEnumerable<DispensarioMedicoUnapec.Models.Medico>

<table class="table table-hover align-middle mb-0">
    <thead class="table-light text-secondary small">
        <tr>
            <th class="ps-4 py-3">Nombre Completo</th>
            <th class="py-3">Cédula</th>
            <th class="py-3">Especialidad</th>
            <th class="py-3">Tanda</th>
            <th class="py-3">No. Carnet</th>
            <th class="py-3">Estado</th>
        </tr>
    </thead>
    <tbody class="border-top-0">
        @foreach (var item in Model)
        {
            <tr>
                <td class="ps-4 fw-semibold text-dark">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px">
                            <i class="bi bi-person-badge text-success small"></i>
                        </div>
                        Dr. @item.Nombre @item.Apellido
                    </div>
                </td>
                <td class="text-muted"><i class="bi bi-person-vcard me-1"></i>@item.Cedula</td>
                <td>
                    <span class="badge bg-light text-dark border rounded-pill px-2">@item.Especialidad</span>
                </td>
                <td>
                    @if (item.TandaLaboral == DispensarioMedicoUnapec.Models.TandaLaboral.Matutina)
                    {
                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-2">
                            <i class="bi bi-sunrise me-1"></i>Matutina
                        </span>
                    }
                    else if (item.TandaLaboral == DispensarioMedicoUnapec.Models.TandaLaboral.Vespertina)
                    {
                        <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-2">
                            <i class="bi bi-sunset me-1"></i>Vespertina
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-dark bg-opacity-10 text-dark border border-dark border-opacity-25 rounded-pill px-2">
                            <i class="bi bi-moon me-1"></i>Nocturna
                        </span>
                    }
                </td>
                <td class="text-muted">@(string.IsNullOrEmpty(item.NumeroCarnet) ? "—" : item.NumeroCarnet)</td>
                <td>
                    @if (item.EstadoMedico.ToString() == "A")
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3">
                            <i class="bi bi-check-circle me-1"></i>Activo
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3">
                            <i class="bi bi-x-circle me-1"></i>Inactivo
                        </span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>