@model DispensarioMedicoUnapec.Models.Paciente

@{
    ViewData["Title"] = "Editar Paciente";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-warning py-3">
                    <h5 class="mb-0 text-dark fw-bold"><i class="bi bi-pencil-square me-2"></i>Editar Datos del Paciente</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <!-- Columna Izquierda -->
                            <div class="col-md-6">
                                <h6 class="text-muted border-bottom pb-2 mb-3">Información Personal</h6>
                                
                                <div class="form-group mb-3">
                                    <label asp-for="Nombre" class="form-label text-secondary fw-semibold"></label>
                                    <input asp-for="Nombre" class="form-control" />
                                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                                </div>
                                <div class="form-group mb-3">
                                    <label asp-for="Apellido" class="form-label text-secondary fw-semibold"></label>
                                    <input asp-for="Apellido" class="form-control" />
                                    <span asp-validation-for="Apellido" class="text-danger small"></span>
                                </div>
                                <div class="form-group mb-3">
                                    <label asp-for="FechaNacimiento" class="form-label text-secondary fw-semibold"></label>
                                    <input asp-for="FechaNacimiento" type="date" class="form-control" />
                                    <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                                </div>
                                <div class="form-group mb-3">
                                    <label asp-for="Cedula" class="form-label text-secondary fw-semibold"></label>
                                    <input asp-for="Cedula" class="form-control" />
                                    <span asp-validation-for="Cedula" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Columna Derecha -->
                            <div class="col-md-6">
                                <h6 class="text-muted border-bottom pb-2 mb-3">Contacto y Estado</h6>
                                
                                <div class="form-group mb-3">
                                    <label asp-for="Telefono" class="form-label text-secondary fw-semibold"></label>
                                    <input asp-for="Telefono" class="form-control" />
                                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                                </div>
                                <div class="form-group mb-3">
                                    <label asp-for="Numero_Carnet" class="form-label text-secondary fw-semibold"></label>
                                    <input asp-for="Numero_Carnet" class="form-control" />
                                    <span asp-validation-for="Numero_Carnet" class="text-danger small"></span>
                                </div>
                                <div class="form-group mb-3">
                                    <label asp-for="Tipo_Paciente" class="form-label text-secondary fw-semibold"></label>
                                    <select asp-for="Tipo_Paciente" class="form-select" asp-items="Html.GetEnumSelectList<DispensarioMedicoUnapec.Models.TipoPaciente>()"></select>
                                    <span asp-validation-for="Tipo_Paciente" class="text-danger small"></span>
                                </div>
                                <div class="form-group mb-4">
                                    <label asp-for="Estado_Paciente" class="form-label text-secondary fw-semibold"></label>
                                    <select asp-for="Estado_Paciente" class="form-select">
                                        <option value="0">Activo</option>
                                        <option value="1">Inactivo</option>
                                    </select>
                                    <span asp-validation-for="Estado_Paciente" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light border px-4">Cancelar</a>
                            <button type="submit" class="btn btn-warning px-4 fw-semibold"><i class="bi bi-save me-2"></i>Actualizar Paciente</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
