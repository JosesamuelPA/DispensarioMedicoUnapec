@model DispensarioMedicoUnapec.Models.Paciente
@using DispensarioMedicoUnapec.Models

@{
    ViewData["Title"] = "Detalle del Paciente";
    var visitas = ViewBag.Visitas as List<Visita> ?? new List<Visita>();
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <!-- ===== ENCABEZADO FICHA ===== -->
            <div class="card shadow border-0 rounded-3 mb-4">
                <div class="card-header bg-info text-white py-3 d-flex align-items-center justify-content-between">
                    <h5 class="mb-0"><i class="bi bi-person-vcard me-2"></i>Ficha del Paciente</h5>
                    @if (Model.Estado_Paciente.ToString() == "A")
                    {
                        <span class="badge bg-light text-success border border-success border-opacity-50">
                            <i class="bi bi-check-circle me-1"></i> Activo
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-light text-danger border border-danger border-opacity-50">
                            <i class="bi bi-x-circle me-1"></i> Inactivo
                        </span>
                    }
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-12 text-center mb-4">
                            <div class="display-1 text-info opacity-50 mb-2">
                                <i class="bi bi-person-circle"></i>
                            </div>
                            <h3 class="fw-bold mb-0">@Model.Nombre @Model.Apellido</h3>
                            <p class="text-muted"><i class="bi bi-tag-fill me-1"></i>Paciente @Model.Tipo_Paciente</p>
                        </div>
                    </div>

                    <h6 class="text-secondary fw-bold border-bottom pb-2 mb-3">Datos Generales</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded shadow-sm">
                                <small class="text-muted d-block fw-semibold mb-1">Cédula de Identidad</small>
                                <span class="fs-6">@Model.Cedula</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded shadow-sm">
                                <small class="text-muted d-block fw-semibold mb-1">Fecha de Nacimiento</small>
                                <span class="fs-6">@Model.FechaNacimiento.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    </div>

                    <h6 class="text-secondary fw-bold border-bottom pb-2 mb-3">Datos de Contacto e Institucionales</h6>
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded shadow-sm h-100">
                                <small class="text-muted d-block fw-semibold mb-1"><i class="bi bi-telephone-fill me-1"></i> Teléfono</small>
                                <span class="fs-6">@Model.Telefono</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded shadow-sm h-100">
                                <small class="text-muted d-block fw-semibold mb-1"><i class="bi bi-card-heading me-1"></i> No. Carnet</small>
                                <span class="fs-6">@(string.IsNullOrEmpty(Model.Numero_Carnet) ? "N/A" : Model.Numero_Carnet)</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white p-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Regresar al listado</a>
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning"><i class="bi bi-pencil-square me-2"></i>Editar Datos</a>
                </div>
            </div>

            <!-- ===== HISTORIAL DE VISITAS ===== -->
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between border-bottom">
                    <h6 class="mb-0 fw-bold text-dark">
                        <i class="bi bi-clipboard2-pulse text-info me-2"></i>
                        Historial de Visitas
                        <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-2 ms-2">@visitas.Count</span>
                    </h6>
                    <a asp-controller="Reportes" asp-action="ImprimirExpediente" asp-route-id="@Model.Id"
                       target="_blank" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                        <i class="bi bi-printer me-1"></i> Generar Reporte
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (visitas.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-secondary small">
                                    <tr>
                                        <th class="ps-4">Fecha</th>
                                        <th>Médico Atendiente</th>
                                        <th>Especialidad</th>
                                        <th class="pe-4">Motivo</th>
                                    </tr>
                                </thead>
                                <tbody class="border-top-0">
                                    @foreach (var visita in visitas)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <span class="badge bg-light text-dark border px-2 py-1 rounded-pill">
                                                    <i class="bi bi-calendar3 me-1 text-info"></i>
                                                    @visita.Fecha.ToString("dd/MM/yyyy")
                                                </span>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px">
                                                        <i class="bi bi-person-badge"></i>
                                                    </div>
                                                    <span class="fw-semibold text-dark">
                                                        @(visita.Medico != null ? $"Dr. {visita.Medico.Nombre} {visita.Medico.Apellido}" : "No asignado")
                                                    </span>
                                                </div>
                                            </td>
                                            <td class="text-secondary small">
                                                @(visita.Medico != null ? visita.Medico.Especialidad : "—")
                                            </td>
                                            <td class="pe-4 text-secondary">
                                                @visita.Motivo
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-clipboard2-x fs-1 d-block mb-3 opacity-40 text-secondary"></i>
                            <span class="fs-6">Este paciente no tiene visitas registradas aún.</span>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

