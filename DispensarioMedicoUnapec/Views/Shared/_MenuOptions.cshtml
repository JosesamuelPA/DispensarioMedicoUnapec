@model int
<td class="text-center align-middle" style="width: 140px;">
    <div class="d-flex justify-content-center gap-2">
        <a asp-action="Details" asp-route-id="@Model" class="btn btn-sm btn-outline-primary d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" title="Ver Detalles">
            <i class="bi bi-eye-fill"></i>
        </a>
        <a asp-action="Edit" asp-route-id="@Model" class="btn btn-sm btn-outline-warning d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" title="Editar">
            <i class="bi bi-pencil-fill"></i>
        </a>
        <a asp-action="Delete" asp-route-id="@Model" class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" title="Eliminar">
            <i class="bi bi-trash3-fill"></i>
        </a>
    </div>
</td>