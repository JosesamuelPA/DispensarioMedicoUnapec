@model DispensarioMedicoUnapec.Models.ViewModels.PerfilViewModel
@using DispensarioMedicoUnapec.Models.ViewModels

@{
    ViewData["Title"] = "Mi Perfil";
    var pwVm = ViewBag.CambiarContrasena as CambiarContrasenaViewModel ?? new CambiarContrasenaViewModel();
}

<div class="container-fluid py-4">

    <!-- Encabezado -->
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="h3 fw-bold mb-0" style="color:#0d7ff2;">
                <i class="bi bi-person-circle me-2"></i>Mi Cuenta
            </h1>
            <p class="text-muted mt-1 mb-0">Gestiona tu información personal y seguridad</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessPassword"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-shield-check me-2"></i>@TempData["SuccessPassword"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorPassword"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorPassword"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- ===== COLUMNA IZQUIERDA: Avatar + info rápida ===== -->
        <div class="col-lg-3">
            <div class="card shadow-sm border-0 rounded-4 text-center">
                <div class="card-body p-4">

                    <!-- Avatar con iniciales -->
                    <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                         style="width:90px;height:90px;background:linear-gradient(135deg,#3b82f6,#6366f1);font-size:2rem;color:white;font-weight:700;letter-spacing:1px;">
                        @Model.Iniciales
                    </div>

                    <h5 class="fw-bold mb-0">
                        @(string.IsNullOrEmpty(Model.NombreCompleto) ? Model.Username : Model.NombreCompleto)
                    </h5>
                    <p class="text-muted small mb-2">@Model.Username</p>

                    <span class="badge px-3 py-1 rounded-pill"
                          style="background:rgba(59,130,246,0.12);color:#3b82f6;font-size:0.75rem;">
                        <i class="bi bi-shield-check me-1"></i>@Model.Rol
                    </span>

                    <hr class="my-3">

                    <div class="text-start small">
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <div class="d-flex align-items-center gap-2 mb-2 text-muted">
                                <i class="bi bi-envelope text-primary"></i>
                                <span>@Model.Email</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Telefono))
                        {
                            <div class="d-flex align-items-center gap-2 mb-2 text-muted">
                                <i class="bi bi-telephone text-success"></i>
                                <span>@Model.Telefono</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Cargo))
                        {
                            <div class="d-flex align-items-center gap-2 mb-2 text-muted">
                                <i class="bi bi-briefcase text-warning"></i>
                                <span>@Model.Cargo</span>
                            </div>
                        }
                        @if (string.IsNullOrEmpty(Model.Email) && string.IsNullOrEmpty(Model.Telefono) && string.IsNullOrEmpty(Model.Cargo))
                        {
                            <p class="text-muted fst-italic text-center">Completa tu perfil para ver la información aquí.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== COLUMNA DERECHA: Formularios ===== -->
        <div class="col-lg-9">

            <!-- Tabs -->
            <ul class="nav nav-pills mb-4 gap-2" id="perfilTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active px-4 rounded-pill" id="tab-perfil" data-bs-toggle="pill"
                            data-bs-target="#pane-perfil" type="button" role="tab">
                        <i class="bi bi-person me-2"></i>Información Personal
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link px-4 rounded-pill" id="tab-seguridad" data-bs-toggle="pill"
                            data-bs-target="#pane-seguridad" type="button" role="tab">
                        <i class="bi bi-shield-lock me-2"></i>Seguridad
                    </button>
                </li>
            </ul>

            <div class="tab-content">

                <!-- ===== TAB PERFIL ===== -->
                <div class="tab-pane fade show active" id="pane-perfil" role="tabpanel">
                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                            <h6 class="fw-bold mb-0"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Datos del Perfil</h6>
                            <small class="text-muted">Esta información será visible en el sistema.</small>
                        </div>
                        <div class="card-body px-4 pb-4">
                            <form asp-action="GuardarPerfil" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="Id" />

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="NombreCompleto" class="form-label text-secondary fw-semibold small"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-person text-muted"></i>
                                            </span>
                                            <input asp-for="NombreCompleto" class="form-control border-start-0 ps-0"
                                                   placeholder="Ej. Juan Pérez" />
                                        </div>
                                        <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label text-secondary fw-semibold small">Usuario</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-at text-muted"></i>
                                            </span>
                                            <input class="form-control border-start-0 ps-0 bg-light" value="@Model.Username" disabled />
                                        </div>
                                        <small class="text-muted">El nombre de usuario no puede cambiarse.</small>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="Email" class="form-label text-secondary fw-semibold small"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-envelope text-muted"></i>
                                            </span>
                                            <input asp-for="Email" class="form-control border-start-0 ps-0"
                                                   placeholder="correo@unapec.edu.do" />
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="Telefono" class="form-label text-secondary fw-semibold small"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-telephone text-muted"></i>
                                            </span>
                                            <input asp-for="Telefono" class="form-control border-start-0 ps-0"
                                                   placeholder="(809) 000-0000" />
                                        </div>
                                        <span asp-validation-for="Telefono" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12">
                                        <label asp-for="Cargo" class="form-label text-secondary fw-semibold small"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-briefcase text-muted"></i>
                                            </span>
                                            <input asp-for="Cargo" class="form-control border-start-0 ps-0"
                                                   placeholder="Ej. Enfermero, Administrador..." />
                                        </div>
                                        <span asp-validation-for="Cargo" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end mt-4">
                                    <button type="submit" class="btn btn-primary px-5 rounded-pill">
                                        <i class="bi bi-check-circle me-2"></i>Guardar Cambios
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- ===== TAB SEGURIDAD ===== -->
                <div class="tab-pane fade" id="pane-seguridad" role="tabpanel">
                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                            <h6 class="fw-bold mb-0"><i class="bi bi-lock me-2 text-danger"></i>Cambiar Contraseña</h6>
                            <small class="text-muted">Usa una contraseña segura de al menos 6 caracteres.</small>
                        </div>
                        <div class="card-body px-4 pb-4">
                            <form asp-action="CambiarContrasena" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="UsuarioId" value="@Model.Id" />

                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label text-secondary fw-semibold small">Contraseña Actual</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-key text-muted"></i>
                                            </span>
                                            <input type="password" name="ContrasenaActual"
                                                   class="form-control border-start-0 ps-0"
                                                   placeholder="Ingresa tu contraseña actual" required />
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label text-secondary fw-semibold small">Nueva Contraseña</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-lock text-muted"></i>
                                            </span>
                                            <input type="password" name="NuevaContrasena" id="nuevaPass"
                                                   class="form-control border-start-0 ps-0"
                                                   placeholder="Mín. 6 caracteres" required minlength="6" />
                                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                                    onclick="togglePass('nuevaPass', this)" title="Mostrar/Ocultar">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label text-secondary fw-semibold small">Confirmar Contraseña</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-lock-fill text-muted"></i>
                                            </span>
                                            <input type="password" name="ConfirmarContrasena" id="confirmarPass"
                                                   class="form-control border-start-0 ps-0"
                                                   placeholder="Repite la nueva contraseña" required />
                                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                                    onclick="togglePass('confirmarPass', this)" title="Mostrar/Ocultar">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Fortaleza visual -->
                                    <div class="col-12">
                                        <small class="text-muted">Fortaleza de la contraseña:</small>
                                        <div class="progress mt-1" style="height:5px;">
                                            <div id="strengthBar" class="progress-bar" role="progressbar" style="width:0%;transition:width 0.3s;"></div>
                                        </div>
                                        <small id="strengthLabel" class="text-muted"></small>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end mt-4">
                                    <button type="submit" class="btn btn-danger px-5 rounded-pill">
                                        <i class="bi bi-shield-lock me-2"></i>Actualizar Contraseña
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Info de sesión -->
                    <div class="card shadow-sm border-0 rounded-4 mt-4">
                        <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                            <h6 class="fw-bold mb-0"><i class="bi bi-info-circle me-2 text-info"></i>Información de la Cuenta</h6>
                        </div>
                        <div class="card-body px-4 pb-4">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="p-3 bg-light rounded-3">
                                        <small class="text-muted d-block fw-semibold mb-1">Nombre de usuario</small>
                                        <span class="fw-bold">@Model.Username</span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 bg-light rounded-3">
                                        <small class="text-muted d-block fw-semibold mb-1">Rol en el sistema</small>
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-2 py-1">
                                            <i class="bi bi-shield me-1"></i>@Model.Rol
                                        </span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 bg-light rounded-3">
                                        <small class="text-muted d-block fw-semibold mb-1">Sesión activa desde</small>
                                        <span class="fw-semibold text-success">
                                            <i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>
                                            Hoy @DateTime.Now.ToString("HH:mm")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- /tab-content -->
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Activate correct tab from URL hash ────────────────────────
    function activateTabFromHash() {
        const hash = window.location.hash;
        if (hash === '#seguridad') {
            bootstrap.Tab.getOrCreateInstance(document.getElementById('tab-seguridad')).show();
        } else {
            bootstrap.Tab.getOrCreateInstance(document.getElementById('tab-perfil')).show();
        }
    }

    document.addEventListener('DOMContentLoaded', activateTabFromHash);
    window.addEventListener('hashchange', activateTabFromHash);
    function togglePass(id, btn) {
        const input = document.getElementById(id);
        if (input.type === 'password') {
            input.type = 'text';
            btn.querySelector('i').className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            btn.querySelector('i').className = 'bi bi-eye';
        }
    }

    // Password strength meter
    document.getElementById('nuevaPass')?.addEventListener('input', function () {
        const val = this.value;
        const bar = document.getElementById('strengthBar');
        const lbl = document.getElementById('strengthLabel');
        let strength = 0;
        if (val.length >= 6) strength++;
        if (val.length >= 10) strength++;
        if (/[A-Z]/.test(val)) strength++;
        if (/[0-9]/.test(val)) strength++;
        if (/[^A-Za-z0-9]/.test(val)) strength++;

        const colors = ['#ef4444', '#f97316', '#eab308', '#22c55e', '#16a34a'];
        const labels = ['Muy débil', 'Débil', 'Moderada', 'Fuerte', 'Muy fuerte'];
        const pct    = (strength / 5) * 100;
        bar.style.width           = pct + '%';
        bar.style.backgroundColor = colors[strength - 1] || '#e5e7eb';
        lbl.textContent           = val.length ? labels[strength - 1] || '' : '';
        lbl.style.color           = colors[strength - 1] || '';
    });
</script>
}
