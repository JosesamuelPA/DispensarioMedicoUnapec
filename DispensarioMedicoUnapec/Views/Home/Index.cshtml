@using DispensarioMedicoUnapec.Models
@{
    ViewData["Title"] = "Panel Principal";
    var ultimasVisitas = ViewBag.UltimasVisitas as List<Visita> ?? new List<Visita>();
}

<div class="container-fluid py-4">

    <!-- ===== ENCABEZADO ===== -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="h3 fw-bold mb-0" style="color: #0d7ff2;">Panel de Control</h1>
            <p class="text-muted mt-1 mb-0">Dispensario Médico APEC — <span id="horaActual" class="fw-semibold text-secondary"></span></p>
        </div>
        <div class="col-md-4 text-md-end mt-2 mt-md-0">
            <a asp-controller="Visitas" asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-circle me-2"></i>Nueva Consulta
            </a>
        </div>
    </div>

    <!-- ===== TARJETAS DE RESUMEN ===== -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center" style="width:52px;height:52px;flex-shrink:0">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-semibold">Pacientes</div>
                        <div class="fw-bold fs-4 lh-1">@ViewBag.TotalPacientes</div>
                        <a asp-controller="Pacientes" asp-action="Index" class="text-primary small text-decoration-none">Ver todos →</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center" style="width:52px;height:52px;flex-shrink:0">
                        <i class="bi bi-person-badge-fill fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-semibold">Médicos</div>
                        <div class="fw-bold fs-4 lh-1">@ViewBag.TotalMedicos</div>
                        <a asp-controller="Medicos" asp-action="Index" class="text-success small text-decoration-none">Ver todos →</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-warning bg-opacity-10 text-warning d-flex align-items-center justify-content-center" style="width:52px;height:52px;flex-shrink:0">
                        <i class="bi bi-capsule-pill fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-semibold">Medicamentos</div>
                        <div class="fw-bold fs-4 lh-1">@ViewBag.TotalMedicamentos</div>
                        <a asp-controller="Medicamentos" asp-action="Index" class="text-warning small text-decoration-none">Ver todos →</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background:#0d7ff2;">
                <div class="card-body d-flex align-items-center gap-3 text-white">
                    <div class="rounded-3 bg-white bg-opacity-25 text-white d-flex align-items-center justify-content-center" style="width:52px;height:52px;flex-shrink:0">
                        <i class="bi bi-calendar-check-fill fs-4"></i>
                    </div>
                    <div>
                        <div class="text-white-50 small fw-semibold">Visitas Hoy</div>
                        <div class="fw-bold fs-4 lh-1">@ViewBag.TotalVisitasHoy</div>
                        <a asp-controller="Visitas" asp-action="Index" class="text-white-50 small text-decoration-none">Ver registro →</a>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- ===== ÚLTIMAS 5 VISITAS ===== -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 pt-4 px-4 pb-2 d-flex align-items-center justify-content-between">
            <div>
                <h5 class="fw-bold mb-0" style="color:#0d7ff2;">
                    <i class="bi bi-clock-history me-2"></i>Últimas Consultas Registradas
                </h5>
                <p class="text-muted small mb-0 mt-1">Los 5 pacientes más recientes por fecha de visita</p>
            </div>
            <a asp-controller="Visitas" asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill px-3">Ver todas</a>
        </div>
        <div class="card-body px-4 pb-4 pt-2">
            @if (ultimasVisitas.Any())
            {
                <div class="table-responsive">
                    <table class="table table-borderless align-middle">
                        <thead class="border-bottom">
                            <tr class="text-muted small">
                                <th class="py-2 fw-semibold">Paciente</th>
                                <th class="py-2 fw-semibold">Médico Atendiente</th>
                                <th class="py-2 fw-semibold">Especialidad</th>
                                <th class="py-2 fw-semibold">Motivo</th>
                                <th class="py-2 fw-semibold">Fecha</th>
                                <th class="py-2 fw-semibold text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var visita in ultimasVisitas)
                            {
                                <tr class="border-bottom border-light-subtle">
                                    <td class="py-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;flex-shrink:0">
                                                <i class="bi bi-person-fill text-primary"></i>
                                            </div>
                                            <div>
                                                <div class="fw-semibold text-dark lh-1">
                                                    @(visita.Paciente != null ? $"{visita.Paciente.Nombre} {visita.Paciente.Apellido}" : "—")
                                                </div>
                                                @if (visita.Paciente != null)
                                                {
                                                    <small class="text-muted">@visita.Paciente.Cedula</small>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <span class="fw-medium text-dark">
                                            @(visita.Medico != null ? $"Dr. {visita.Medico.Nombre} {visita.Medico.Apellido}" : "—")
                                        </span>
                                    </td>
                                    <td class="py-3">
                                        <span class="badge bg-light text-secondary border rounded-pill px-2">
                                            @(visita.Medico != null ? visita.Medico.Especialidad : "—")
                                        </span>
                                    </td>
                                    <td class="py-3 text-muted" style="max-width:180px;">
                                        <span class="d-inline-block text-truncate" style="max-width:160px;" title="@visita.Motivo">
                                            @visita.Motivo
                                        </span>
                                    </td>
                                    <td class="py-3">
                                        @{
                                            var esHoy = visita.Fecha.Date == DateTime.Today;
                                            var esAyer = visita.Fecha.Date == DateTime.Today.AddDays(-1);
                                        }
                                        <div class="lh-1">
                                            <div class="fw-semibold text-dark">
                                                @if (esHoy) { <span class="text-success">Hoy</span> }
                                                else if (esAyer) { <span class="text-warning">Ayer</span> }
                                                else { @visita.Fecha.ToString("dd/MM/yyyy") }
                                            </div>
                                            <small class="text-muted">@visita.Fecha.ToString("HH:mm")</small>
                                        </div>
                                    </td>
                                    <td class="py-3 text-center">
                                        @if (visita.Paciente != null)
                                        {
                                            <a asp-controller="Pacientes" asp-action="Details" asp-route-id="@visita.Paciente.Id"
                                               class="btn btn-sm btn-outline-info rounded-pill px-3" title="Ver expediente del paciente">
                                                <i class="bi bi-folder2-open me-1"></i> Expediente
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-clipboard2-pulse fs-1 d-block mb-3 opacity-40"></i>
                    <span class="fs-6">No hay consultas registradas aún. <a asp-controller="Visitas" asp-action="Create">Registrar primera consulta →</a></span>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    function actualizarHora() {
        const ahora = new Date();
        const opciones = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' };
        document.getElementById('horaActual').textContent = ahora.toLocaleDateString('es-DO', opciones);
    }
    actualizarHora();
    setInterval(actualizarHora, 60000);
</script>
}
