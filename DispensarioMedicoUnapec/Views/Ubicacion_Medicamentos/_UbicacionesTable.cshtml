@model IEnumerable<DispensarioMedicoUnapec.Models.Ubicacion_Medicamento>

<div class="table-responsive shadow-sm rounded-3 border">
    <table class="table table-hover align-middle mb-0 bg-white">
        <thead class="table-light text-secondary">
            <tr>
                <th class="ps-4">Medicamento</th>
                <th>Estante</th>
                <th>
                    @Html.DisplayNameFor(model => model.Tramo)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Celda)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.EstadoMedicamento)
                </th>
                <th class="text-center">Gestionar</th>
            </tr>
        </thead>
        <tbody class="border-top-0">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold text-dark">
                            <i class="bi bi-bookmark-fill me-1 text-primary"></i> 
                            @(item.Medicamento != null ? item.Medicamento.Nombre : "Sin Medicina")
                        </td>
                        <td class="text-secondary">
                            <i class="bi bi-box-seam me-1 text-secondary"></i>
                            @(item.Estante != null ? item.Estante.Nombre : "No asignado")
                        </td>
                        <td>
                            @if (item.Tramo.ToString().Contains("Inferior"))
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-2 py-1">
                                    <i class="bi bi-arrow-down me-1"></i> @item.Tramo
                                </span>
                            }
                            else if (item.Tramo.ToString().Contains("Superior"))
                            {
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-2 py-1">
                                    <i class="bi bi-arrow-up me-1"></i> @item.Tramo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-2 py-1">
                                    <i class="bi bi-dash Lg me-1"></i> @item.Tramo
                                </span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border px-2 py-1 rounded-pill">
                                @Html.DisplayFor(modelItem => item.Celda)
                            </span>
                        </td>
                        <td>
                            @if (item.EstadoMedicamento.ToString() == "A")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1">
                                    <i class="bi bi-check-circle me-1"></i> Activo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-1">
                                    <i class="bi bi-x-circle me-1"></i> Inactivo
                                </span>
                            }
                        </td>
                        <partial name="_MenuOptions" model="item.Id" />
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-search fs-1 d-block mb-3 text-secondary opacity-50"></i>
                        <span class="fs-5">No se encontraron ubicaciones con estos criterios</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center p-3 border-top bg-light">
            <span class="text-muted small fw-semibold">Página @ViewBag.CurrentPage de @ViewBag.TotalPages</span>
            <nav aria-label="Navegación de páginas">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link" onclick="loadPage(@(ViewBag.CurrentPage - 1))">Anterior</button>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <button class="page-link" onclick="loadPage(@i)">@i</button>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <button class="page-link" onclick="loadPage(@(ViewBag.CurrentPage + 1))">Siguiente</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
