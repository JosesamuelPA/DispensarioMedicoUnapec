@model DispensarioMedicoUnapec.Models.Ubicacion_Medicamento

@{
    ViewData["Title"] = "Detalle de Ubicación";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-info text-white py-3 d-flex align-items-center justify-content-between">
                    <h5 class="mb-0"><i class="bi bi-geo-alt-fill me-2"></i>Ficha de Ubicación</h5>
                    <span class="badge bg-light text-dark">@Model.EstadoMedicamento</span>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="display-1 text-info opacity-50 mb-3 mt-2">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <h2 class="fw-bold text-dark mb-2">@(Model.Medicamento != null ? Model.Medicamento.Nombre : "Sin Medicina")</h2>
                    <h5 class="text-secondary mb-2">Estante: @(Model.Estante != null ? Model.Estante.Nombre : "No Asignado")</h5>
                    <h6 class="text-secondary mb-4">Tramo (Nivel): @Model.Tramo | Celda (Columna): @Model.Celda</h6>
                </div>
                <div class="card-footer bg-white p-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Regresar al listado</a>
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning"><i class="bi bi-pencil-square me-2"></i>Editar Datos</a>
                </div>
            </div>
        </div>
    </div>
</div>
