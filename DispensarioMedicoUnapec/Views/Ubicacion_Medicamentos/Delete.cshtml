@model DispensarioMedicoUnapec.Models.Ubicacion_Medicamento

@{
    ViewData["Title"] = "Eliminar Ubicación";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="alert alert-danger d-flex align-items-center shadow-sm mb-4 border-0" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-2 me-3"></i>
                <div>
                    <h5 class="alert-heading mb-1 fw-bold">Borrado Definitivo</h5>
                    <div class="mb-0">¿Seguro que deseas eliminar este registro de ubicación física? Esto podría dejar medicamentos sin ubicar si estaban asignados aquí.</div>
                </div>
            </div>

            <div class="card shadow border-danger border-opacity-50 rounded-3">
                <div class="card-body p-4 text-center">
                    <div class="display-3 text-danger opacity-50 mb-3 mt-2">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <h2 class="fw-bold text-dark mb-2">@(Model.Medicamento != null ? Model.Medicamento.Nombre : "Sin Medicina")</h2>
                    <h5 class="text-secondary mb-2">Estante: @(Model.Estante != null ? Model.Estante.Nombre : "No Asignado")</h5>
                    <h6 class="text-secondary mb-4">Tramo (Nivel): @Model.Tramo | Celda (Columna): @Model.Celda</h6>
                    <p class="text-danger fw-semibold">Estado actual: @Model.EstadoMedicamento</p>
                </div>
                <div class="card-footer bg-light p-3 border-top-0 d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Cancelar</a>
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash-fill me-2"></i>Eliminar Registro
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
