@model DispensarioMedicoUnapec.Views.LoginViewModel.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Dispensario Médico UNAPEC — Iniciar Sesión";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            height: 100dvh;
            display: flex;
            overflow: hidden;
            background: #0f172a;
        }

        /* ═══ LEFT PANEL ═══════════════════════════════════════════ */
        .left-panel {
            flex: 1.1;
            background: linear-gradient(160deg, #0f172a 0%, #1e293b 60%, #0f2952 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            padding: 4rem 4rem 4rem 5rem;
            position: relative;
            overflow: hidden;
        }

        /* Decorative circles */
        .left-panel::before {
            content: '';
            position: absolute;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%);
            border-radius: 50%;
            top: -120px; left: -120px;
            pointer-events: none;
        }
        .left-panel::after {
            content: '';
            position: absolute;
            width: 380px; height: 380px;
            background: radial-gradient(circle, rgba(99,102,241,0.10) 0%, transparent 70%);
            border-radius: 50%;
            bottom: -80px; right: -60px;
            pointer-events: none;
        }

        .brand-logo {
            width: 64px; height: 64px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            border-radius: 18px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem;
            color: white;
            margin-bottom: 2rem;
            box-shadow: 0 8px 24px rgba(59,130,246,0.4);
        }

        .left-panel h1 {
            font-size: 2.4rem;
            font-weight: 700;
            color: #ffffff;
            line-height: 1.2;
            margin-bottom: 1rem;
        }

        .left-panel p {
            font-size: 1rem;
            color: rgba(255,255,255,0.55);
            max-width: 380px;
            line-height: 1.6;
            margin-bottom: 2.5rem;
        }

        .feature-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .feature-list li {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255,255,255,0.7);
            font-size: 0.88rem;
        }
        .feature-list li .fi-icon {
            width: 32px; height: 32px;
            background: rgba(59,130,246,0.15);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            color: #60a5fa;
            font-size: 0.9rem;
            flex-shrink: 0;
        }

        /* ═══ RIGHT PANEL ═══════════════════════════════════════════ */
        .right-panel {
            flex: 0 0 480px;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem 3rem;
        }

        .login-box {
            width: 100%;
            max-width: 380px;
        }

        .login-box h2 {
            font-size: 1.6rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 0.4rem;
        }

        .login-box .subtitle {
            color: #64748b;
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }

        /* Inputs */
        .field-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: #475569;
            letter-spacing: 0.03em;
            margin-bottom: 6px;
            display: block;
        }

        .input-icon-wrap {
            position: relative;
        }
        .input-icon-wrap .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1rem;
            pointer-events: none;
        }
        .input-icon-wrap input {
            width: 100%;
            padding: 12px 14px 12px 42px;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            font-size: 0.9rem;
            background: #f8fafc;
            color: #0f172a;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s;
        }
        .input-icon-wrap input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
            background: #fff;
        }
        .input-icon-wrap .toggle-pass {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #94a3b8;
            cursor: pointer;
            font-size: 0.95rem;
            padding: 2px;
        }
        .input-icon-wrap .toggle-pass:hover { color: #3b82f6; }

        .form-group { margin-bottom: 1.25rem; }

        /* Error message */
        .error-banner {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: 10px 14px;
            color: #dc2626;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 1.25rem;
        }

        /* Submit button */
        .btn-login {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            letter-spacing: 0.03em;
            cursor: pointer;
            transition: opacity 0.18s, transform 0.12s;
            margin-top: 0.5rem;
        }
        .btn-login:hover { opacity: 0.92; transform: translateY(-1px); }
        .btn-login:active { transform: translateY(0); }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 1.5rem 0;
            color: #cbd5e1;
            font-size: 0.78rem;
        }
        .divider hr { flex: 1; border-color: #e2e8f0; }

        .btn-register {
            width: 100%;
            padding: 12px;
            background: transparent;
            color: #3b82f6;
            border: 1.5px solid #3b82f6;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
            text-decoration: none;
            display: block;
            text-align: center;
        }
        .btn-register:hover { background: #eff6ff; color: #2563eb; }

        .footer-copy {
            font-size: 0.72rem;
            color: #94a3b8;
            text-align: center;
            margin-top: 2.5rem;
        }

        /* Responsive */
        @@media (max-width: 900px) {
            .left-panel { display: none; }
            body { background: #f8fafc; }
            .right-panel {
                flex: 1;
                background: transparent;
            }
        }
    </style>
</head>
<body>

    <!-- ═══ LEFT PANEL ═══════════════════════════════════════ -->
    <div class="left-panel">
        <div class="brand-logo">
            <i class="bi bi-hospital-fill"></i>
        </div>

        <h1>Dispensario<br>Médico APEC</h1>
        <p>Sistema integral de gestión clínica para el control de pacientes, médicos, medicamentos y consultas.</p>

        <ul class="feature-list">
            <li>
                <div class="fi-icon"><i class="bi bi-people-fill"></i></div>
                Gestión de pacientes y médicos
            </li>
            <li>
                <div class="fi-icon"><i class="bi bi-capsule-pill"></i></div>
                Control de inventario farmacéutico
            </li>
            <li>
                <div class="fi-icon"><i class="bi bi-calendar-check-fill"></i></div>
                Registro de consultas y visitas
            </li>
            <li>
                <div class="fi-icon"><i class="bi bi-file-earmark-bar-graph-fill"></i></div>
                Reportes y estadísticas en tiempo real
            </li>
        </ul>
    </div>

    <!-- ═══ RIGHT PANEL ═══════════════════════════════════════ -->
    <div class="right-panel">
        <div class="login-box">

            <h2>Bienvenido</h2>
            <p class="subtitle">Inicia sesión para acceder al sistema</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-banner">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span>
                        @foreach (var state in ViewData.ModelState.Values)
                        {
                            foreach (var error in state.Errors)
                            {
                                @error.ErrorMessage
                            }
                        }
                    </span>
                </div>
            }

            <form asp-controller="Auth" asp-action="Login" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="field-label" for="Username">Usuario</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-person field-icon"></i>
                        <input asp-for="Username" id="Username" type="text"
                               placeholder="Nombre de usuario" autocomplete="username" required />
                    </div>
                    <span asp-validation-for="Username" class="text-danger" style="font-size:0.78rem;"></span>
                </div>

                <div class="form-group">
                    <label class="field-label" for="Password">Contraseña</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-lock field-icon"></i>
                        <input asp-for="Password" id="Password" type="password"
                               placeholder="••••••••" autocomplete="current-password" required />
                        <button type="button" class="toggle-pass" onclick="togglePass()" title="Mostrar/ocultar">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="font-size:0.78rem;"></span>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
                </button>
            </form>

            <div class="divider"><hr />o<hr /></div>

            <a asp-controller="Auth" asp-action="Register" class="btn-register">
                <i class="bi bi-person-plus me-2"></i>Crear una cuenta
            </a>

            <div class="footer-copy">
                © 2026 Dispensario Médico APEC · Todos los derechos reservados
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePass() {
            const input   = document.getElementById('Password');
            const icon    = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type     = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type     = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
</body>
</html>