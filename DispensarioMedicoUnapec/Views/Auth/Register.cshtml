@model DispensarioMedicoUnapec.Views.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Dispensario Médico UNAPEC — Crear Cuenta";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            height: 100dvh;
            display: flex;
            overflow: hidden;
            background: #0f172a;
        }

        /* ═══ LEFT PANEL ═══════════════════════════════════════════ */
        .left-panel {
            flex: 1.1;
            background: linear-gradient(160deg, #0f172a 0%, #1e293b 60%, #0f2952 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            padding: 4rem 4rem 4rem 5rem;
            position: relative;
            overflow: hidden;
        }

        .left-panel::before {
            content: '';
            position: absolute;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%);
            border-radius: 50%;
            top: -120px; left: -120px;
            pointer-events: none;
        }
        .left-panel::after {
            content: '';
            position: absolute;
            width: 380px; height: 380px;
            background: radial-gradient(circle, rgba(99,102,241,0.10) 0%, transparent 70%);
            border-radius: 50%;
            bottom: -80px; right: -60px;
            pointer-events: none;
        }

        .brand-logo {
            width: 64px; height: 64px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            border-radius: 18px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem;
            color: white;
            margin-bottom: 2rem;
            box-shadow: 0 8px 24px rgba(59,130,246,0.4);
        }

        .left-panel h1 {
            font-size: 2.4rem;
            font-weight: 700;
            color: #ffffff;
            line-height: 1.2;
            margin-bottom: 1rem;
        }

        .left-panel p {
            font-size: 1rem;
            color: rgba(255,255,255,0.55);
            max-width: 380px;
            line-height: 1.6;
            margin-bottom: 2.5rem;
        }

        .step-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }
        .step-list li {
            display: flex;
            align-items: center;
            gap: 14px;
            color: rgba(255,255,255,0.7);
            font-size: 0.88rem;
        }
        .step-num {
            width: 28px; height: 28px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: white;
            font-size: 0.72rem;
            font-weight: 700;
            flex-shrink: 0;
        }

        /* ═══ RIGHT PANEL ═══════════════════════════════════════════ */
        .right-panel {
            flex: 0 0 500px;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            overflow-y: auto;
        }

        .register-box {
            width: 100%;
            max-width: 400px;
        }

        .register-box h2 {
            font-size: 1.6rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 0.4rem;
        }

        .register-box .subtitle {
            color: #64748b;
            font-size: 0.9rem;
            margin-bottom: 1.75rem;
        }

        .field-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: #475569;
            letter-spacing: 0.03em;
            margin-bottom: 6px;
            display: block;
        }

        .input-icon-wrap { position: relative; }
        .input-icon-wrap .field-icon {
            position: absolute;
            left: 14px; top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1rem;
            pointer-events: none;
        }
        .input-icon-wrap input {
            width: 100%;
            padding: 12px 14px 12px 42px;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            font-size: 0.9rem;
            background: #f8fafc;
            color: #0f172a;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s;
        }
        .input-icon-wrap input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
            background: #fff;
        }
        .input-icon-wrap .toggle-pass {
            position: absolute;
            right: 12px; top: 50%;
            transform: translateY(-50%);
            background: none; border: none;
            color: #94a3b8; cursor: pointer;
            font-size: 0.95rem; padding: 2px;
        }
        .input-icon-wrap .toggle-pass:hover { color: #3b82f6; }

        .form-group { margin-bottom: 1.1rem; }

        .error-banner {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: 10px 14px;
            color: #dc2626;
            font-size: 0.85rem;
            display: flex; align-items: flex-start; gap: 8px;
            margin-bottom: 1.25rem;
        }

        /* Password strength */
        .strength-bar-wrap { height: 4px; background: #e2e8f0; border-radius: 4px; margin-top: 6px; overflow: hidden; }
        .strength-bar { height: 100%; width: 0; border-radius: 4px; transition: width 0.3s, background 0.3s; }

        .btn-register {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            letter-spacing: 0.03em;
            cursor: pointer;
            transition: opacity 0.18s, transform 0.12s;
            margin-top: 0.5rem;
        }
        .btn-register:hover { opacity: 0.92; transform: translateY(-1px); }
        .btn-register:active { transform: translateY(0); }

        .divider {
            display: flex; align-items: center; gap: 12px;
            margin: 1.25rem 0;
            color: #cbd5e1; font-size: 0.78rem;
        }
        .divider hr { flex: 1; border-color: #e2e8f0; }

        .btn-login-link {
            width: 100%;
            padding: 12px;
            background: transparent;
            color: #3b82f6;
            border: 1.5px solid #3b82f6;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: block; text-align: center;
            transition: background 0.15s, color 0.15s;
        }
        .btn-login-link:hover { background: #eff6ff; color: #2563eb; }

        .footer-copy {
            font-size: 0.72rem; color: #94a3b8;
            text-align: center; margin-top: 2rem;
        }

        @@media (max-width: 900px) {
            .left-panel { display: none; }
            body { background: #f8fafc; }
            .right-panel { flex: 1; background: transparent; }
        }
    </style>
</head>
<body>

    <!-- ═══ LEFT PANEL ═══════════════════════════════════════ -->
    <div class="left-panel">
        <div class="brand-logo">
            <i class="bi bi-hospital-fill"></i>
        </div>

        <h1>Crear tu<br>cuenta</h1>
        <p>Solo los administradores autorizados pueden registrarse en el sistema. Completa los campos para obtener acceso.</p>

        <ul class="step-list">
            <li><div class="step-num">1</div>Elige un nombre de usuario único</li>
            <li><div class="step-num">2</div>Crea una contraseña segura (mín. 6 caracteres)</li>
            <li><div class="step-num">3</div>Confirma tu contraseña</li>
            <li><div class="step-num">4</div>Accede al sistema y configura tu perfil</li>
        </ul>
    </div>

    <!-- ═══ RIGHT PANEL ═══════════════════════════════════════ -->
    <div class="right-panel">
        <div class="register-box">

            <h2>Crear cuenta</h2>
            <p class="subtitle">Completa el formulario para registrarte en el sistema</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-banner">
                    <i class="bi bi-exclamation-circle-fill mt-1"></i>
                    <span>
                        @foreach (var state in ViewData.ModelState.Values)
                        {
                            foreach (var error in state.Errors)
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        }
                    </span>
                </div>
            }

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="error-banner" style="background:#f0fdf4;border-color:#bbf7d0;color:#16a34a;">
                    <i class="bi bi-check-circle-fill mt-1"></i>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }

            <form asp-controller="Auth" asp-action="Register" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="field-label" for="Username">Nombre de usuario</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-person field-icon"></i>
                        <input asp-for="Username" id="Username" type="text"
                               placeholder="Ej. admin_juan" autocomplete="username" required />
                    </div>
                    <span asp-validation-for="Username" class="text-danger" style="font-size:0.78rem;"></span>
                </div>

                <div class="form-group">
                    <label class="field-label" for="Password">Contraseña</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-lock field-icon"></i>
                        <input asp-for="Password" id="Password" type="password"
                               placeholder="Mín. 6 caracteres" autocomplete="new-password" required
                               oninput="checkStrength(this.value)" />
                        <button type="button" class="toggle-pass" onclick="togglePass('Password','eye1')" title="Mostrar/ocultar">
                            <i class="bi bi-eye" id="eye1"></i>
                        </button>
                    </div>
                    <div class="strength-bar-wrap mt-1">
                        <div class="strength-bar" id="strengthBar"></div>
                    </div>
                    <small id="strengthLabel" class="text-muted" style="font-size:0.72rem;"></small>
                    <span asp-validation-for="Password" class="text-danger d-block" style="font-size:0.78rem;"></span>
                </div>

                <div class="form-group">
                    <label class="field-label" for="ConfirmPassword">Confirmar contraseña</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-lock-fill field-icon"></i>
                        <input asp-for="ConfirmPassword" id="ConfirmPassword" type="password"
                               placeholder="Repite la contraseña" autocomplete="new-password" required />
                        <button type="button" class="toggle-pass" onclick="togglePass('ConfirmPassword','eye2')" title="Mostrar/ocultar">
                            <i class="bi bi-eye" id="eye2"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger d-block" style="font-size:0.78rem;"></span>
                </div>

                <button type="submit" class="btn-register">
                    <i class="bi bi-person-plus me-2"></i>Crear Cuenta
                </button>
            </form>

            <div class="divider"><hr />¿Ya tienes cuenta?<hr /></div>

            <a asp-controller="Auth" asp-action="Login" class="btn-login-link">
                <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
            </a>

            <div class="footer-copy">
                © 2026 Dispensario Médico UNAPEC · Todos los derechos reservados
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type     = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type     = 'password';
                icon.className = 'bi bi-eye';
            }
        }

        function checkStrength(val) {
            const bar = document.getElementById('strengthBar');
            const lbl = document.getElementById('strengthLabel');
            let s = 0;
            if (val.length >= 6) s++;
            if (val.length >= 10) s++;
            if (/[A-Z]/.test(val)) s++;
            if (/[0-9]/.test(val)) s++;
            if (/[^A-Za-z0-9]/.test(val)) s++;

            const colors = ['#ef4444','#f97316','#eab308','#22c55e','#16a34a'];
            const labels = ['Muy débil','Débil','Moderada','Fuerte','Muy fuerte'];
            const pct    = (s / 5) * 100;
            bar.style.width           = val.length ? pct + '%' : '0';
            bar.style.background      = colors[s - 1] || '#e2e8f0';
            lbl.textContent           = val.length ? (labels[s - 1] || '') : '';
            lbl.style.color           = colors[s - 1] || '';
        }
    </script>
</body>
</html>