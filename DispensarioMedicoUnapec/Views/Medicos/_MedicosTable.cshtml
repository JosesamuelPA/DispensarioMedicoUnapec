@model IEnumerable<DispensarioMedicoUnapec.Models.Medico>

<div class="table-responsive shadow-sm rounded-3 border">
    <table class="table table-hover align-middle mb-0 bg-white">
        <thead class="table-light text-secondary">
            <tr>
                <th class="ps-4">
                    @Html.DisplayNameFor(model => model.Nombre)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Apellido)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Cedula)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Especialidad)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.TandaLaboral)
                </th>
                <th>
                    Estado
                </th>
                <th class="text-center">Gestionar</th>
            </tr>
        </thead>
        <tbody class="border-top-0">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold text-dark">
                            @Html.DisplayFor(modelItem => item.Nombre)
                        </td>
                        <td class="text-secondary">
                            @Html.DisplayFor(modelItem => item.Apellido)
                        </td>
                        <td>
                            <i class="bi bi-person-vcard text-muted me-1"></i> @Html.DisplayFor(modelItem => item.Cedula)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Especialidad)
                        </td>
                        <td>
                            @if (item.TandaLaboral.ToString() == "Matutina")
                            {
                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-2 py-1">
                                    <i class="bi bi-sunrise me-1"></i> Matutina
                                </span>
                            }
                            else if (item.TandaLaboral.ToString() == "Vespertina")
                            {
                                <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-2 py-1">
                                    <i class="bi bi-sunset me-1"></i> Vespertina
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-dark bg-opacity-10 text-dark border border-dark border-opacity-25 rounded-pill px-2 py-1">
                                    <i class="bi bi-moon me-1"></i> @item.TandaLaboral
                                </span>
                            }
                        </td>
                        <td>
                            @if (item.EstadoMedico.ToString() == "A")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1">
                                    <i class="bi bi-check-circle me-1"></i> Activo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-1">
                                    <i class="bi bi-x-circle me-1"></i> Inactivo
                                </span>
                            }
                        </td>
                        <partial name="_MenuOptions" model="item.Id" />
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-5 text-muted">
                        <i class="bi bi-search fs-1 d-block mb-3 text-secondary opacity-50"></i>
                        <span class="fs-5">No se encontraron médicos con estos criterios</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center p-3 border-top bg-light">
            <span class="text-muted small fw-semibold">Página @ViewBag.CurrentPage de @ViewBag.TotalPages</span>
            <nav aria-label="Navegación de páginas">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link" onclick="loadPage(@(ViewBag.CurrentPage - 1))">Anterior</button>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <button class="page-link" onclick="loadPage(@i)">@i</button>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <button class="page-link" onclick="loadPage(@(ViewBag.CurrentPage + 1))">Siguiente</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
