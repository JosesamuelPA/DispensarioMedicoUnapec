@model DispensarioMedicoUnapec.Models.Visita

@{
    ViewData["Title"] = "Registrar Visita";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white pt-4 pb-3">
                    <h5 class="mb-0"><i class="bi bi-calendar-plus me-2"></i>Agendar / Registrar Visita Médica</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="PacienteId" class="form-label text-secondary fw-semibold">Paciente</label>
                                    <select asp-for="PacienteId" class="form-select select-search" asp-items="ViewBag.PacienteId">
                                        <option value="">-- Selecciona un Paciente --</option>
                                    </select>
                                    <span asp-validation-for="PacienteId" class="text-danger small"></span>
                                </div>
                                <div class="form-group mb-3">
                                    <label asp-for="MedicoId" class="form-label text-secondary fw-semibold">Médico Asignado</label>
                                    <select asp-for="MedicoId" class="form-select select-search" asp-items="ViewBag.MedicoId">
                                        <option value="">-- Selecciona un Médico --</option>
                                    </select>
                                    <span asp-validation-for="MedicoId" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Fecha" class="form-label text-secondary fw-semibold">Fecha y Hora</label>
                                    <input asp-for="Fecha" class="form-control" type="datetime-local" />
                                    <span asp-validation-for="Fecha" class="text-danger small"></span>
                                </div>
                                <div class="form-group mb-3">
                                    <label asp-for="Motivo" class="form-label text-secondary fw-semibold">Motivo de Consulta</label>
                                    <textarea asp-for="Motivo" class="form-control" rows="3" placeholder="Ej. Dolor de cabeza, Chequeo de rutina..."></textarea>
                                    <span asp-validation-for="Motivo" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light border px-4">Cancelar</a>
                            <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-2"></i>Guardar Visita</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            $('.select-search').select2({
                theme: 'bootstrap-5',
                width: '100%',
                placeholder: $(this).data('placeholder'),
            });
        });
    </script>
}
