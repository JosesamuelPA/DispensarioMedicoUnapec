@model IEnumerable<DispensarioMedicoUnapec.Models.Medicamento>

<div class="table-responsive shadow-sm rounded-3 border">
    <table class="table table-hover align-middle mb-0 bg-white">
        <thead class="table-light text-secondary">
            <tr>
                <th class="ps-4">
                    @Html.DisplayNameFor(model => model.Nombre)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Descripcion)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Dosis)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Tipo_Farmaco)
                </th>
                <th>
                    Marca
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Estado)
                </th>
                <th class="text-center">Gestionar</th>
            </tr>
        </thead>
        <tbody class="border-top-0">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold text-dark">
                            @Html.DisplayFor(modelItem => item.Nombre)
                        </td>
                        <td class="text-secondary text-truncate" style="max-width: 250px;" title="@item.Descripcion">
                            @Html.DisplayFor(modelItem => item.Descripcion)
                        </td>
                        <td>
                            <i class="bi bi-prescription2 text-muted me-1"></i> @Html.DisplayFor(modelItem => item.Dosis)
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border px-2 py-1 rounded-pill">
                                @Html.DisplayFor(modelItem => item.Tipo_Farmaco.Nombre)
                            </span>
                        </td>
                        <td>
                            <span class="text-primary fw-semibold">
                                @(item.Marca != null ? item.Marca.Nombre : "—")
                            </span>
                        </td>
                        <td>
                            @if (item.Estado == "Disponible")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1">
                                    <i class="bi bi-check-circle me-1"></i> @item.Estado
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-1">
                                    <i class="bi bi-x-circle me-1"></i> @item.Estado
                                </span>
                            }
                        </td>
                        <partial name="_MenuOptions" model="item.Id" />
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-search fs-1 d-block mb-3 text-secondary opacity-50"></i>
                        <span class="fs-5">No se encontraron medicamentos con estos criterios</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center p-3 border-top bg-light">
            <span class="text-muted small fw-semibold">Página @ViewBag.CurrentPage de @ViewBag.TotalPages</span>
            <nav aria-label="Navegación de páginas">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link" onclick="loadPage(@(ViewBag.CurrentPage - 1))">Anterior</button>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <button class="page-link" onclick="loadPage(@i)">@i</button>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <button class="page-link" onclick="loadPage(@(ViewBag.CurrentPage + 1))">Siguiente</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
