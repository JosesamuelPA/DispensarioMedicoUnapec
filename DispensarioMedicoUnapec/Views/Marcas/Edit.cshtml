@model DispensarioMedicoUnapec.Models.Marca

@{
    ViewData["Title"] = "Editar Marca";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-warning py-3">
                    <h5 class="mb-0 text-dark fw-bold"><i class="bi bi-pencil-square me-2"></i>Editar Marca Comercial</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Nombre" class="form-label text-secondary fw-semibold"></label>
                                    <input asp-for="Nombre" class="form-control" />
                                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label text-secondary fw-semibold">País de Origen</label>
                                    @{
                                        ViewData["FieldName"]  = "Pais";
                                        ViewData["FieldId"]    = "Pais";
                                        ViewData["FieldValue"] = Model.Pais ?? "";
                                        ViewData["Required"]   = false;
                                    }
                                    <partial name="_PaisSelector" />
                                    <span asp-validation-for="Pais" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-group mb-2">
                                    <label asp-for="Descripcion" class="form-label text-secondary fw-semibold">Descripción</label>
                                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-5 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light border px-4">Cancelar</a>
                            <button type="submit" class="btn btn-warning px-4 fw-semibold"><i class="bi bi-save me-2"></i>Actualizar Marca</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
