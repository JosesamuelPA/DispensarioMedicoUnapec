@model DispensarioMedicoUnapec.Models.Marca

@{
    ViewData["Title"] = "Eliminar Marca";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="alert alert-danger d-flex align-items-center shadow-sm mb-4 border-0" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-2 me-3"></i>
                <div>
                    <h5 class="alert-heading mb-1 fw-bold">Borrado Definitivo</h5>
                    <div class="mb-0">¿Estás absolutamente seguro de que deseas eliminar la marca de fabricante "@Model.Nombre"?</div>
                </div>
            </div>

            <div class="card shadow border-danger border-opacity-50 rounded-3">
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-12 text-center mb-2">
                            <h3 class="fw-bold text-dark mb-0">@Model.Nombre</h3>
                            <p class="text-danger fw-semibold"><i class="bi bi-geo-alt-fill me-1"></i>@Model.Pais</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <div class="p-3 bg-light rounded border text-center">
                                <small class="text-muted d-block fw-semibold mb-1">Descripción</small>
                                <span class="fs-6 text-dark">@Model.Descripcion</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light p-3 border-top-0 d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Cancelar y Regresar</a>
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash-fill me-2"></i>Confirmar Eliminación
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
