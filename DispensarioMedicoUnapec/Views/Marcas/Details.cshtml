@model DispensarioMedicoUnapec.Models.Marca

@{
    ViewData["Title"] = "Detalle de Marca";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-info text-white py-3 d-flex align-items-center justify-content-between">
                    <h5 class="mb-0"><i class="bi bi-briefcase-fill me-2"></i>Ficha de la Marca</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-12 text-center mb-4">
                            <div class="display-1 text-info opacity-50 mb-2">
                                <i class="bi bi-building"></i>
                            </div>
                            <h3 class="fw-bold mb-0">@Model.Nombre</h3>
                            <p class="text-muted"><i class="bi bi-geo-alt-fill me-1"></i>País: @Model.Pais</p>
                        </div>
                    </div>

                    <h6 class="text-secondary fw-bold border-bottom pb-2 mb-3">Información y Notas</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-12">
                            <div class="p-4 bg-light rounded shadow-sm text-center">
                                <span class="fs-6 text-dark fst-italic">"@Model.Descripcion"</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white p-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Regresar al listado</a>
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning"><i class="bi bi-pencil-square me-2"></i>Editar Datos</a>
                </div>
            </div>
        </div>
    </div>
</div>
